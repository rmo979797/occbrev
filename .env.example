# Environment: 'production' on Railway, leave blank locally.
ENVIRONMENT=production

# Postgres in production (Railway auto-injects this when you add a Postgres
# plugin). Local dev defaults to ./waitlist.db (SQLite).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# HTTP Basic Auth credentials for /api/waitlist/admin.
# Generate a strong random password — anyone who knows these can export
# the full waitlist.
ADMIN_USER=admin
ADMIN_PASS=replace-me-with-a-long-random-string

# Optional — Sentry DSN. Leave blank to disable error reporting.
SENTRY_DSN=

# Optional — version label shown in Sentry releases.
APP_VERSION=1.0.0
